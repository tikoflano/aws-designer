{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/aws-designer.server.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@compiler/*": ["server/compiler/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["server/src/**/*.ts", "shared/**/*.ts", "server/compiler/**/*.ts"]
}
